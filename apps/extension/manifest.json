{
  "manifest_version": 3,
  "name": "Crisp — Make AI Sound Like You",
  "version": "0.1.0",
  "description": "Detects AI-generated text when you paste and rewrites it in your voice. Works in Gmail, Slack, Notion, LinkedIn, and everywhere else.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://*.crisp.app/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "public/popup.html",
    "default_icon": {
      "16": "public/icon-16.png",
      "48": "public/icon-48.png",
      "128": "public/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "icons": {
    "16": "public/icon-16.png",
    "48": "public/icon-48.png",
    "128": "public/icon-128.png"
  }
}
